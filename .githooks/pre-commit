#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [ ! -x vendor/bin/phpcs ] || [ ! -x vendor/bin/phpcbf ]; then
    echo "PHP_CodeSniffer is not installed. Run: composer install"
    exit 1
fi

php_files=()
while IFS= read -r -d '' file; do
    php_files+=("$file")
done < <(git diff --cached --name-only -z --diff-filter=ACMR -- '*.php')

if [ "${#php_files[@]}" -eq 0 ]; then
    exit 0
fi

vendor/bin/phpcbf --standard=phpcs.xml.dist "${php_files[@]}"
git add -- "${php_files[@]}"
vendor/bin/phpcs --standard=phpcs.xml.dist "${php_files[@]}"
