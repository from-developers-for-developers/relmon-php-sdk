<?xml version="1.0"?>
<ruleset name="RelMon">
    <description>PSR-12 and PSR-1 coding standard for RelMon.</description>

    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="4"/>

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>
