{
    "name": "from-developers-for-developers/relmon-php-sdk",
    "description": "Official PHP SDK for RelMon protocol",
    "type": "sdk",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "FromDevelopersForDevelopers\\RelMon\\": "src/",
            "FromDevelopersForDevelopers\\RelMon\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Dmitrijs Abrosimovs",
            "email": "abrosimovs@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "composer/semver": "^3.4"
    },
    "config": {
        "platform": {
            "php": "8.0.0"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.10",
        "phpstan/phpstan": "^2.1",
        "php-parallel-lint/php-parallel-lint": "^1.4"
    },
    "scripts": {
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "lint": "vendor/bin/parallel-lint -p php --exclude vendor src tests",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
        "quality": [
            "@lint",
            "@analyse"
        ]
    },
    "suggest": {
        "ext-dom": "Recommended for XML parsing tests and DOMDocument-based RelMon inputs.",
        "ext-simplexml": "Recommended for XML parsing tests and SimpleXMLElement-based RelMon inputs."
    }
}
